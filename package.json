{
  "name": "chat-web",
  "private": true,
  "description": "A modern full-stack template powered by Cloudflare Workers, using Hono for backend APIs, React Router for frontend routing, and shadcn/ui for beautiful, accessible components styled with Tailwind CSS",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply chat-web-db --local",
    "db:seed": "wrangler d1 execute chat-web-db --local --command \"INSERT OR IGNORE INTO conversations (id, user_id, title, model, created_at, updated_at) VALUES ('demo-conversation', 'local-user', '数据库验证会话', 'deepseek-v4-flash', datetime('now'), datetime('now')); INSERT OR IGNORE INTO messages (id, conversation_id, role, content, model, status, created_at) VALUES ('demo-message', 'demo-conversation', 'user', '这是一条数据库插入验证消息', 'deepseek-v4-flash', 'done', datetime('now'));\"",
    "deploy": "pnpm run build && wrangler deploy",
    "dev": "react-router dev",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --react-plugin --jsx-a11y-plugin",
    "lint:fix": "oxlint . --react-plugin --jsx-a11y-plugin --fix",
    "preview": "pnpm run build && vite preview",
    "typecheck": "pnpm run cf-typegen && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-slot": "^1.3.0",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "4.11.1",
    "isbot": "5.1.32",
    "lucide-react": "^1.22.0",
    "radix-ui": "^1.6.1",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-router": "7.9.6",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.15.3",
    "@cloudflare/workers-types": "^4.20260507.1",
    "@react-router/dev": "7.9.6",
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "5.1.4",
    "wrangler": "4.88.0"
  },
  "cloudflare": {
    "label": "React Router + Hono Fullstack App",
    "products": [
      "Workers"
    ],
    "categories": [
      "starter"
    ],
    "docs_url": "https://developers.cloudflare.com/workers",
    "preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/d3db20ee-c3bf-4b5c-f1ed-d86021359e00/public",
    "preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/56caa8a9-d3ab-4ac6-32a9-6a5fc686e000/preview",
    "publish": true
  }
}
